import express from 'express';
import path from 'path';
import fs from 'fs';
import { fileURLToPath } from 'url';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

const app = express();
const PORT = process.env.PORT || 3000;

app.use(express.json());

// Enable CORS
app.use((req, res, next) => {
  res.header('Access-Control-Allow-Origin', '*');
  res.header('Access-Control-Allow-Headers', 'Origin, X-Requested-With, Content-Type, Accept');
  res.header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
  next();
});

const SHARED_DIR = '/home/team/shared';
const DATA_DIR = path.join(__dirname, 'data');

if (!fs.existsSync(DATA_DIR)) {
  fs.mkdirSync(DATA_DIR, { recursive: true });
}

// Helper to extract metadata from markdown
function parseGuide(filename, content) {
  const lines = content.split('\n');
  let title = filename.replace('.md', '').split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
  let description = 'Learn a practical, step-by-step path to building wealth and passive income starting from $0.';
  
  // Try to find first H1 for title
  for (const line of lines) {
    if (line.startsWith('# ')) {
      title = line.substring(2).trim();
      break;
    }
  }
  
  // Try to find first non-empty paragraph or blockquote for description
  for (let i = 0; i < lines.length; i++) {
    const line = lines[i].trim();
    if (line && !line.startsWith('#') && !line.startsWith('---') && !line.startsWith('!')) {
      if (line.startsWith('>')) {
        description = line.substring(1).trim();
      } else {
        description = line.substring(0, 150) + (line.length > 150 ? '...' : '');
      }
      break;
    }
  }

  const slug = filename.replace('.md', '');
  return {
    slug,
    filename,
    title,
    description,
    content
  };
}

// GET list of guides
app.get('/api/guides', (req, res) => {
  try {
    if (!fs.existsSync(SHARED_DIR)) {
      return res.json({ success: true, guides: [] });
    }
    const files = fs.readdirSync(SHARED_DIR);
    const guides = files
      .filter(file => file.endsWith('.md'))
      .map(file => {
        const filePath = path.join(SHARED_DIR, file);
        const content = fs.readFileSync(filePath, 'utf8');
        return parseGuide(file, content);
      });
    
    // Sort guides by filename/order
    guides.sort((a, b) => a.filename.localeCompare(b.filename));
    
    res.json({ success: true, guides });
  } catch (error) {
    console.error('Error reading shared guides:', error);
    res.status(500).json({ success: false, error: 'Could not read shared guide files' });
  }
});

// GET single guide
app.get('/api/guides/:slug', (req, res) => {
  try {
    const slug = req.params.slug;
    const filePath = path.join(SHARED_DIR, `${slug}.md`);
    if (fs.existsSync(filePath)) {
      const content = fs.readFileSync(filePath, 'utf8');
      const guide = parseGuide(`${slug}.md`, content);
      res.json({ success: true, guide });
    } else {
      res.status(404).json({ success: false, error: 'Guide not found' });
    }
  } catch (error) {
    res.status(500).json({ success: false, error: 'Error reading guide' });
  }
});

// POST signup
app.post('/api/signup', (req, res) => {
  const { name, email } = req.body;
  if (!email) {
    return res.status(400).json({ success: false, error: 'Email is required' });
  }
  
  try {
    const signupPath = path.join(SHARED_DIR, 'signups.json');
    let signups = [];
    if (fs.existsSync(signupPath)) {
      try {
        signups = JSON.parse(fs.readFileSync(signupPath, 'utf8'));
      } catch (e) {
        signups = [];
      }
    }
    
    signups.push({
      name: name || '',
      email,
      timestamp: new Date().toISOString()
    });
    
    fs.writeFileSync(signupPath, JSON.stringify(signups, null, 2));
    
    res.json({ success: true, message: 'Signup recorded successfully!' });
  } catch (error) {
    console.error('Error saving signup:', error);
    res.status(500).json({ success: false, error: 'Could not record signup' });
  }
});

// Serve static assets from build output
app.use(express.static(path.join(__dirname, 'dist')));

// SPA Fallback: serve index.html for any other routes
app.get('*', (req, res) => {
  res.sendFile(path.join(__dirname, 'dist', 'index.html'));
});

app.listen(PORT, '0.0.0.0', () => {
  console.log(`Zero to Wealth server listening on port ${PORT}...`);
});
